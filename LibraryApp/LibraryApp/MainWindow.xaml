<Window x:Class="LibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой книг" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="📚 Управление библиотекой книг" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <!-- Панель кнопок управления авторами и жанрами -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="ManageAuthorsBtn" Content="👤 Управление авторами" 
                    Width="180" Height="35" Margin="5" 
                    Background="LightBlue" Click="ManageAuthorsBtn_Click"/>
            <Button x:Name="ManageGenresBtn" Content="🏷️ Управление жанрами" 
                    Width="180" Height="35" Margin="5" 
                    Background="LightBlue" Click="ManageGenresBtn_Click"/>
        </StackPanel>

        <!-- Панель поиска и фильтрации -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" Margin="5" 
                         Height="25" TextChanged="SearchBox_TextChanged"/>

                <TextBlock Text="📖 Жанр:" Grid.Column="2" 
                           VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="GenreFilterCombo" Grid.Column="3" Margin="5" 
                          Height="25" DisplayMemberPath="Name" 
                          SelectionChanged="Filter_Changed"/>

                <Button x:Name="ClearFilterBtn" Grid.Column="4" Content="Сброс" 
                        Width="80" Height="25" Margin="5" Click="ClearFilterBtn_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid для книг -->
        <DataGrid x:Name="BooksGrid" Grid.Row="3" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,10" SelectionMode="Single"
                  AlternatingRowBackground="LightGray" AlternationCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="250"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="150"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding GenreName}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок для книг (ДОБАВИТЬ, РЕДАКТИРОВАТЬ, УДАЛИТЬ) -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="AddBookBtn" Content="➕ Добавить книгу" 
                    Width="140" Height="35" Margin="5" 
                    Background="LightGreen" FontWeight="Bold" 
                    Click="AddBookBtn_Click"/>
            <Button x:Name="EditBookBtn" Content="✏️ Редактировать книгу" 
                    Width="160" Height="35" Margin="5" 
                    Background="LightYellow" Click="EditBookBtn_Click"/>
            <Button x:Name="DeleteBookBtn" Content="❌ Удалить книгу" 
                    Width="140" Height="35" Margin="5" 
                    Background="LightPink" Click="DeleteBookBtn_Click"/>
        </StackPanel>

        <!-- Статус бар -->
        <StatusBar Grid.Row="5" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="BooksCountText" Text="Всего книг: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>