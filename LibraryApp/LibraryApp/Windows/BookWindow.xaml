<Window x:Class="LibraryApp.Windows.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleText" Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Добавление книги" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <!-- Название -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="TitleBox" Grid.Row="1" Grid.Column="1" 
                 Margin="5" Height="25" Padding="3"/>

        <!-- Автор -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Автор:" 
                   VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="AuthorCombo" Grid.Row="2" Grid.Column="1" 
                  DisplayMemberPath="FullName" Margin="5" Height="25"/>

        <!-- Год -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Год издания:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="YearBox" Grid.Row="3" Grid.Column="1" 
                 Margin="5" Height="25" Padding="3" Text="2024"/>

        <!-- ISBN -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="ISBN:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="IsbnBox" Grid.Row="4" Grid.Column="1" 
                 Margin="5" Height="25" Padding="3"/>

        <!-- Жанр -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Жанр:" 
                   VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="GenreCombo" Grid.Row="5" Grid.Column="1" 
                  DisplayMemberPath="Name" Margin="5" Height="25"/>

        <!-- Количество -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="В наличии:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="QuantityBox" Grid.Row="6" Grid.Column="1" 
                 Margin="5" Height="25" Padding="3" Text="1"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button x:Name="SaveBtn" Content="✅ Сохранить" 
                    Width="120" Height="35" Margin="10" 
                    Background="LightGreen" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="❌ Отмена" 
                    Width="120" Height="35" Margin="10" 
                    Background="LightPink" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>