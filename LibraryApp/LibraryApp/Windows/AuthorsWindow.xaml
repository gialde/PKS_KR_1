<Window x:Class="LibraryApp.Windows.AuthorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление авторами" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторы" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <DataGrid x:Name="AuthorsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,10" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="120"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="AddBtn" Content="Добавить" Width="100" Height="30" Margin="5" Click="AddBtn_Click"/>
            <Button x:Name="EditBtn" Content="Редактировать" Width="100" Height="30" Margin="5" Click="EditBtn_Click"/>
            <Button x:Name="DeleteBtn" Content="Удалить" Width="100" Height="30" Margin="5" Click="DeleteBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>