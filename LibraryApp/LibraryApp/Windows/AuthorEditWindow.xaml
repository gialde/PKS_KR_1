<Window x:Class="LibraryApp.Windows.AuthorEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автор" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Автор" FontSize="18" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="LastNameBox" Grid.Row="2" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Страна:" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="CountryBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center" Margin="5"/>
        <DatePicker x:Name="BirthDatePicker" Grid.Row="4" Grid.Column="1" Margin="5" Height="25"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="30" 
                    Margin="5" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="30" 
                    Margin="5" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
