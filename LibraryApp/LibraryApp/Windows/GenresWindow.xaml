<Window x:Class="LibraryApp.Windows.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Жанры" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <DataGrid x:Name="GenresGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,10" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="AddBtn" Content="Добавить" Width="100" Height="30" Margin="5" Click="AddBtn_Click"/>
            <Button x:Name="EditBtn" Content="Редактировать" Width="100" Height="30" Margin="5" Click="EditBtn_Click"/>
            <Button x:Name="DeleteBtn" Content="Удалить" Width="100" Height="30" Margin="5" Click="DeleteBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>